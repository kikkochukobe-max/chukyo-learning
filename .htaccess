	php_value auto_prepend_file '/home/users/2/racoo03/web/chukyokobetsu.com/manage/wordfence-waf.php'
</IfModule>
<IfModule mod_php7.c>
	php_value auto_prepend_file '/home/users/2/racoo03/web/chukyokobetsu.com/manage/wordfence-waf.php'
</IfModule>
<IfModule mod_php.c>
	php_value auto_prepend_file '/home/users/2/racoo03/web/chukyokobetsu.com/manage/wordfence-waf.php'
